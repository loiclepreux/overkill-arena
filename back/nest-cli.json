{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/api-gateway",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "users-service": {
      "type": "application",
      "root": "apps/users-service",
      "entryFile": "main",
      "sourceRoot": "apps/users-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/users-service/tsconfig.app.json"
      }
    },
    "teams-service": {
      "type": "application",
      "root": "apps/teams-service",
      "entryFile": "main",
      "sourceRoot": "apps/teams-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/teams-service/tsconfig.app.json"
      }
    },
    "tournaments-service": {
      "type": "application",
      "root": "apps/tournaments-service",
      "entryFile": "main",
      "sourceRoot": "apps/tournaments-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/tournaments-service/tsconfig.app.json"
      }
    },
    "matches-service": {
      "type": "application",
      "root": "apps/matches-service",
      "entryFile": "main",
      "sourceRoot": "apps/matches-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/matches-service/tsconfig.app.json"
      }
    },
    "rewards-service": {
      "type": "application",
      "root": "apps/rewards-service",
      "entryFile": "main",
      "sourceRoot": "apps/rewards-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/rewards-service/tsconfig.app.json"
      }
    },
    "notifications-service": {
      "type": "application",
      "root": "apps/notifications-service",
      "entryFile": "main",
      "sourceRoot": "apps/notifications-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notifications-service/tsconfig.app.json"
      }
    }
  }
}