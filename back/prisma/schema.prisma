generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PLAYER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  pseudo    String   @unique
  email     String   @unique
  password  String
  role      Role     @default(PLAYER)
  createdAt DateTime @default(now())
}

model Profile {
  id           String  @id @default(uuid())
  userId       String  @unique
  pseudo       String
  avatar       String?
  bio          String?
  country      String?
  favoriteGame String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserStats {
  id     String @id @default(uuid())
  userId String @unique

  elo   Int @default(1000)
  xp    Int @default(0)
  level Int @default(1)

  wins   Int @default(0)
  losses Int @default(0)

  tournamentsPlayed Int @default(0)
  tournamentsWon    Int @default(0)

  rank String @default("Bronze")
}

enum TeamRole {
  CAPTAIN
  CO_CAPTAIN
  MEMBER
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Team {
  id          String  @id @default(uuid())
  name        String  @unique
  tag         String  @unique
  logo        String?
  description String?

  captainId String

  createdAt DateTime @default(now())

  members  TeamMember[]
  requests TeamJoinRequest[]
}

model TeamMember {
  id String @id @default(uuid())

  teamId String
  userId String @unique

  role TeamRole @default(MEMBER)

  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])

  @@index([teamId])
}

model TeamJoinRequest {
  id String @id @default(uuid())

  teamId String
  userId String

  status JoinRequestStatus @default(PENDING)

  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])

  @@unique([teamId, userId])
}
